# Feishu AM Workbench runtime configuration (example only)
# Copy to .env locally and fill real values. Do not commit .env.

# Optional: full Base URL, used to parse base token and customer table id.
# FEISHU_AM_WORKBENCH_BASE_URL=https://my.feishu.cn/base/<base_token>?table=<customer_master_table_id>&view=<view_id>

# Recommended explicit values
FEISHU_AM_BASE_TOKEN=app_example_base_token
FEISHU_AM_CUSTOMER_MASTER_TABLE_ID=tbl_customer_master_example
FEISHU_AM_CUSTOMER_ARCHIVE_FOLDER=fld_customer_archive_example
FEISHU_AM_MEETING_NOTES_FOLDER=fld_meeting_notes_example
FEISHU_AM_TODO_TASKLIST_GUID=00000000-0000-4000-8000-000000000001

# Optional Todo custom field overrides
# FEISHU_AM_TODO_CUSTOMER_FIELD_GUID=<guid>
# FEISHU_AM_TODO_PRIORITY_FIELD_GUID=<guid>
